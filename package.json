{
  "name": "vouch-night-handover",
  "version": "1.0.0",
  "description": "Automated night-shift handover service for hotel front desks",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cypress:run": "cypress run",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^7.1.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^15.18.0",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9",
    "webpack": "^5.107.2"
  }
}
